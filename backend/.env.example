# ===========================================================================
# DocuMorph backend — copy to .env and fill in. Never commit the real .env.
# ===========================================================================

# ── Azure OpenAI (chat + embeddings) ───────────────────────────────────────
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_KEY=
AZURE_OPENAI_API_VERSION="2024-08-01-preview"
AZURE_OPENAI_DEPLOYMENT=
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=   # text-embedding-3-large deployment name

# ── Azure Document Intelligence (optional, scanned-PDF OCR) ─────────────────
AZURE_DI_ENDPOINT=
AZURE_DI_KEY=

# ── Neon Postgres ───────────────────────────────────────────────────────────
NEON_DATABASE_URL=postgresql://USER:PASSWORD@HOST/DB?sslmode=require

# ── Qdrant Cloud ─────────────────────────────────────────────────────────────
QDRANT_URL=
QDRANT_API_KEY=

# ── Cloudflare R2 (S3 API) ───────────────────────────────────────────────────
R2_ACCOUNT_ID=
R2_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=

# ── App knobs ─────────────────────────────────────────────────────────────────
ENV=development
LOG_LEVEL=INFO
STORAGE_BACKEND=auto
EMBEDDING_MODEL=text-embedding-3-large
EMBEDDING_DIM=3072
MAX_UPLOAD_MB=100
OCR_CHAR_THRESHOLD=50
CORS_ORIGINS=*

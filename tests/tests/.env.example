# Copy to tests/.env and fill in real values. The .env file itself is
# git-ignored. Every value here is optional — the pipeline degrades to
# deterministic fallbacks when a credential is missing.

# Azure OpenAI — section mapping, rewriting, document-understanding refinement
AZURE_OPENAI_ENDPOINT=https://<resource>.openai.azure.com/
AZURE_OPENAI_KEY=
AZURE_OPENAI_DEPLOYMENT=gpt-5-chat
AZURE_OPENAI_API_VERSION=2025-01-01-preview

# Azure Document Intelligence — OCR + semantic layout for scanned PDFs
AZURE_DI_ENDPOINT=https://<resource>.cognitiveservices.azure.com/
AZURE_DI_KEY=

# Optional: explicit LibreOffice binary path (auto-detected otherwise)
# SOFFICE_BIN=/Applications/LibreOffice.app/Contents/MacOS/soffice

# Optional: override the Domain Profiles directory (defaults to
# tests/domain_profiles/)
# DOMAIN_PROFILES_DIR=/path/to/profiles

# Optional: tuning knobs
# OCR_CHAR_THRESHOLD=50    # avg chars/page below which a PDF is treated as scanned
# MAX_UPLOAD_MB=100
